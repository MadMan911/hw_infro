# App
APP_PORT=8000
LOG_LEVEL=info

# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# Mock LLM (comma-separated URLs for multiple instances)
MOCK_LLM_URLS=http://mock-llm-1:8001,http://mock-llm-2:8001,http://mock-llm-3:8001

# Balancer strategy: round_robin, weighted, latency_based
BALANCING_STRATEGY=round_robin

# Agent LLM models (LiteLLM format)
AGENT_CHEAP_MODEL=openai/gpt-4o-mini
AGENT_STRONG_MODEL=openrouter/deepseek/deepseek-chat-v3-0324
AGENT_MAX_STEPS=6

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=agent-platform

# Prometheus
PROMETHEUS_PORT=9090

# MLFlow
MLFLOW_TRACKING_URI=http://mlflow:5000

# Auth
AUTH_SECRET_KEY=change-me-in-production
AUTH_ENABLED=false
